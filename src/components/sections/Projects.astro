---
const projects = [
  {
    title: "Sistema de Análisis de Apuestas Deportivas",
    description: "Automatización del análisis de partidos con detección de oportunidades de valor comparando probabilidades teóricas con cuotas reales. Detecta apuestas con probabilidad superior al 70%.",
    tags: ["Python", "SQLite", "Tkinter"],
    image: "⚽",
    liveUrl: "#",
    repoUrl: "https://github.com/JudseFasa",
  },
  {
    title: "Scraper de Datos Deportivos",
    description: "Extracción de datos históricos de partidos (HT/FT, goles, estadísticas) de fuentes como Flashscore y SoccerStats. Base de datos con más de 2 años de historial para análisis predictivo.",
    tags: ["Python", "Playwright", "Supabase"],
    image: "🕷️",
    liveUrl: "#",
    repoUrl: "https://github.com/JudseFasa",
  },
  {
    title: "Sistema de Registro y Análisis de Apuestas",
    description: "Clasificación de apuestas (ganadas/perdidas) y medición de rentabilidad. Control detallado de rendimiento por tipo de apuesta.",
    tags: ["Python", "SQLite", "Tkinter"],
    image: "📊",
    liveUrl: "#",
    repoUrl: "https://github.com/JudseFasa",
  },
  {
    title: "Herramienta de Análisis H2H (Head-to-Head)",
    description: "Detección de tendencias y patrones entre equipos para predicción de resultados deportivos mediante análisis de enfrentamientos directos.",
    tags: ["Python", "Tkinter"],
    image: "🔍",
    liveUrl: "#",
    repoUrl: "https://github.com/JudseFasa",
  },
];
---

<section id="proyectos" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-sm uppercase tracking-widest text-primary-light mb-3 font-semibold">Proyectos</h2>
      <h3 class="text-3xl sm:text-4xl font-bold">
        Mis <span class="text-accent">proyectos</span> destacados
      </h3>
      <p class="text-text-secondary mt-4 max-w-2xl mx-auto">
        Proyectos enfocados en automatización, scraping y análisis de datos deportivos.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div class="group rounded-2xl bg-surface-light border border-white/5 hover:border-primary/20 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/5">
          <div class="h-48 bg-gradient-to-br from-surface-lighter to-surface flex items-center justify-center text-6xl group-hover:scale-105 transition-transform duration-500">
            {project.image}
          </div>

          <div class="p-6">
            <h4 class="text-xl font-bold mb-2 group-hover:text-primary-light transition-colors">
              {project.title}
            </h4>
            <p class="text-text-secondary text-sm leading-relaxed mb-4">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2 mb-5">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 text-xs font-medium bg-primary/10 text-primary-light rounded-full border border-primary/20">
                  {tag}
                </span>
              ))}
            </div>

            <div class="flex items-center gap-4">
              <a
                href={project.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-sm text-text-secondary hover:text-primary-light transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                Código
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
