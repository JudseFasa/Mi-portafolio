---
const certifications = [
  {
    name: "Técnico CASD",
    issuer: "CASD",
    date: "Completado",
    url: "#",
    icon: "🏆",
  },
  {
    name: "Cursos Jóvenes 4.0",
    issuer: "MinTIC Colombia",
    date: "Completado",
    url: "#",
    icon: "🚀",
  },
  {
    name: "Técnico en el SENA",
    issuer: "SENA",
    date: "Completado",
    url: "#",
    icon: "🎖️",
  },
];
---

<section id="certificaciones" class="py-20 lg:py-28 bg-surface-light/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-sm uppercase tracking-widest text-primary-light mb-3 font-semibold">Certificaciones</h2>
      <h3 class="text-3xl sm:text-4xl font-bold">
        Mis <span class="text-accent">certificaciones</span>
      </h3>
      <p class="text-text-secondary mt-4 max-w-2xl mx-auto">
        Formación profesional y técnica certificada.
      </p>
    </div>

    <!-- Certifications Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {certifications.map((cert) => (
        <a
          href={cert.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group p-5 rounded-2xl bg-surface border border-white/5 hover:border-primary/20 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5 block"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl group-hover:scale-110 transition-transform duration-300 flex-shrink-0">
              {cert.icon}
            </div>
            <div class="flex-1 min-w-0">
              <h4 class="text-sm font-bold text-text-primary group-hover:text-primary-light transition-colors leading-tight mb-1">
                {cert.name}
              </h4>
              <p class="text-xs text-text-secondary">{cert.issuer}</p>
              <span class="text-xs text-text-muted mt-1 inline-block">{cert.date}</span>
            </div>
            <svg class="w-4 h-4 text-text-muted group-hover:text-primary-light transition-all group-hover:translate-x-0.5 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
