---
const experiences = [
  {
    role: "Consultor Independiente en Soporte Técnico",
    company: "Freelance",
    period: "2021 — Presente",
    description: "Diagnóstico y reparación de equipos de cómputo. Asesoría en compra de hardware. Mantenimiento preventivo y correctivo de equipos informáticos.",
    tags: ["Soporte Técnico", "Hardware", "Diagnóstico"],
  },
  {
    role: "Desarrollador de Automatizaciones",
    company: "Proyectos Independientes",
    period: "2023 — Presente",
    description: "Desarrollo de herramientas de scraping, análisis de datos deportivos y automatización de procesos con Python, Playwright y Supabase.",
    tags: ["Python", "Supabase", "Playwright", "Automatización"],
  },
];
---

<section id="experiencia" class="py-20 lg:py-28 bg-surface-light/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-sm uppercase tracking-widest text-primary-light mb-3 font-semibold">Experiencia</h2>
      <h3 class="text-3xl sm:text-4xl font-bold">
        Mi <span class="text-accent">trayectoria</span> profesional
      </h3>
    </div>

    <!-- Timeline -->
    <div class="max-w-3xl mx-auto relative">
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-primary via-accent to-primary/20 md:-translate-x-px"></div>

      {experiences.map((exp, index) => (
        <div class={`relative flex flex-col md:flex-row gap-6 mb-12 last:mb-0 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
          <div class="absolute left-0 md:left-1/2 w-3 h-3 bg-primary rounded-full -translate-x-[5px] md:-translate-x-[6px] mt-2 ring-4 ring-surface z-10"></div>

          <div class={`ml-6 md:ml-0 md:w-1/2 ${index % 2 === 0 ? 'md:pl-8' : 'md:pr-8 md:text-right'}`}>
            <div class="p-6 rounded-2xl bg-surface border border-white/5 hover:border-primary/20 transition-all duration-300 hover:-translate-y-1">
              <span class="text-xs font-medium text-accent mb-2 inline-block">{exp.period}</span>
              <h4 class="text-lg font-bold text-text-primary">{exp.role}</h4>
              <p class="text-primary-light text-sm mb-3">{exp.company}</p>
              <p class="text-text-secondary text-sm leading-relaxed mb-4">{exp.description}</p>
              <div class={`flex flex-wrap gap-2 ${index % 2 === 0 ? '' : 'md:justify-end'}`}>
                {exp.tags.map((tag) => (
                  <span class="px-2.5 py-1 text-xs bg-primary/10 text-primary-light rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
